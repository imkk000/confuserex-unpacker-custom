<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>confuserex_unpacker_custom</RootNamespace>
    <AssemblyName>confuserex-unpacker-custom</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <LangVersion>latest</LangVersion>
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="dnlib">
      <HintPath>libs\dnlib.dll</HintPath>
    </Reference>
    <Reference Include="de4dot.blocks">
      <HintPath>libs\de4dot.blocks.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
